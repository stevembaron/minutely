# Optional: URL of the Cloudflare Worker proxy (see /worker).
# When set, all Pirate Weather requests go through the worker so the API
# key isn't shipped in the client bundle. Leave unset for direct calls
# with the embedded key (fine for local dev, leaky for production).
#
# VITE_API_PROXY_URL=https://soon-weather-proxy.<your-subdomain>.workers.dev
